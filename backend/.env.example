# ======================
# ENTORNO
# ======================
ENVIRONMENT=development
DEBUG=true

# ======================
# BASE DE DATOS
# ======================
# SQLite (recomendado para desarrollo)
DATABASE_URL=sqlite:///./gimnasio.db

# PostgreSQL (para producción)
# DATABASE_URL=postgresql://gimnasio_user:gimnasio_pass@localhost:5432/gimnasio_db

# Configuración del pool (solo PostgreSQL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ======================
# SEGURIDAD
# ======================
# Genera una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ======================
# CORS - Orígenes permitidos
# ======================
# Formato: URLs separadas por comas (sin espacios)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:5173,http://localhost:4200

# ======================
# LLM CONFIGURATION
# ======================
# true = Ollama local (GRATIS), false = Claude API (pago)
USE_LOCAL_LLM=true

# Ollama (LLM local y gratuito)
LOCAL_LLM_MODEL=qwen2.5:14b
LOCAL_LLM_BASE_URL=http://localhost:11434

# Claude API (solo si USE_LOCAL_LLM=false)
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=
BOT_MODEL=claude-3-5-sonnet-20241022
BOT_MAX_TOKENS=1024

# ======================
# BOT DE HOSPITALIDAD
# ======================
BOT_NAME=GymBot
BOT_TEMPERATURE=0.7

# ======================
# TRIGGERS AUTOMÁTICOS
# ======================
# Formato: números separados por comas
TRIGGER_CHECK_INTERVAL_MINUTES=60
RACHA_DIAS_HITOS=7,15,30,60,90
CAMBIO_PESO_KG_HITOS=2,5,10
DIAS_INACTIVIDAD_HITOS=3,7,14

# ======================
# COMPUTER VISION
# ======================
CV_ENABLED=false
CV_CAMERA_URLS=

# ======================
# INFORMACIÓN DEL PROYECTO
# ======================
PROJECT_NAME=Gimnasio API - Sistema Integral
VERSION=2.0.0
DESCRIPTION=API para Sistema de Gestión de Gimnasio con Bot de Hospitalidad

# ======================
# NOTIFICACIONES A OSNE
# ======================
# Twilio WhatsApp (para enviar alertas a Osne)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# SMTP Email (respaldo opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ======================
# NOTAS
# ======================
# 1. NO subas este archivo .env al repositorio
# 2. Copia este archivo a .env y configura tus valores
# 3. Con USE_LOCAL_LLM=true, el sistema usa Ollama (100% GRATIS)
# 4. Primero instala Ollama: curl -fsSL https://ollama.com/install.sh | sh
# 5. Luego descarga el modelo: ollama pull qwen2.5:14b
# 6. Para notificaciones a Osne, configura credenciales de Twilio (opcional)
