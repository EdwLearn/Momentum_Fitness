# ============================================
# MOMENTUM FITNESS - .gitignore
# ============================================

# ===========================================
# Dependencies
# ===========================================
# Frontend
node_modules/
frontend/node_modules/

# Backend Python
venv/
.venv/
backend/.venv/
env/
ENV/
momentum/
.claude/
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ===========================================
# Build Outputs
# ===========================================
# Frontend
.next/
out/
frontend/.next/
frontend/out/

# Backend
backend/dist/
backend/build/
*.spec.bak

# Electron
momentum-fitness-electron/dist/
momentum-fitness-electron/node_modules/

# PyInstaller
*.manifest
*.spec.bak

# ===========================================
# Database
# ===========================================
*.db
*.sqlite
*.sqlite3
backend/*.db
backend/*.sqlite3
backend/gimnasio.db
backend/gimnasio_template.db
gimnasio.db

# ===========================================
# Environment Variables
# ===========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
backend/.env
frontend/.env.local

# Mantener .env.example para referencia
!.env.example
!backend/.env.example

# ===========================================
# Python
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/

# ===========================================
# Next.js / TypeScript
# ===========================================
*.tsbuildinfo
next-env.d.ts

# ===========================================
# Logs
# ===========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/
*.log.*

# ===========================================
# IDEs y Editores
# ===========================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ===========================================
# Sistema Operativo
# ===========================================
.DS_Store
Thumbs.db
desktop.ini
.Spotlight-V100
.Trashes

# ===========================================
# Testing
# ===========================================
coverage/
.nyc_output/
*.lcov

# ===========================================
# Vercel
# ===========================================
.vercel

# ===========================================
# Temporal y Cache
# ===========================================
*.cache
.cache/
tmp/
temp/

# ===========================================
# Archivos Sensibles
# ===========================================
# NO subir claves API reales
# NO subir credenciales de producción
# NO subir datos de usuarios reales